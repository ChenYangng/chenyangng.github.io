      "text": "{\n  \"action_candidates\":[\n    {\n      \"id\":\"act_1\",\n      \"target_id\":\"obj_1\",\n      \"target_type\":\"object\",\n      \"action_type\":\"tap\",\n      \"intent\":\"open_detail\",\n      \"expected_outcome\":\"open_new_view\",\n      \"risk\":\"low\"\n    },\n    {\n      \"id\":\"act_2\",\n      \"target_id\":\"node_btn_1\",\n      \"target_type\":\"node\",\n      \"action_type\":\"tap\",\n      \"intent\":\"trigger_secondary_entry\",\n      \"expected_outcome\":\"open_secondary_action\",\n      \"risk\":\"medium\"\n    },\n    {\n      \"id\":\"act_3\",\n      \"target_id\":\"close_btn\",\n      \"target_type\":\"node\",\n      \"action_type\":\"tap\",\n      \"intent\":\"dismiss_content\",\n      \"expected_outcome\":\"remove_current_card\",\n      \"risk\":\"medium\"\n    }\n  ]\n}",
