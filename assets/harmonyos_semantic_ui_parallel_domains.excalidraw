		{
			"id": "lsBlUkUh",
			"type": "text",
			"x": 1540,
			"y": 290,
			"width": 178.9453125,
			"height": 128.1,
			"angle": 0,
			"strokeColor": "#1f2937",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
