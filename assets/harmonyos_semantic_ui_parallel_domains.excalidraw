		{
			"id": "OrXxSb8y",
			"type": "text",
			"x": 1540,
			"y": 550,
			"width": 275.15625,
			"height": 73.2,
			"angle": 0,
			"strokeColor": "#1f2937",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"roundness": null,
			"seed": 1529119091,
			"version": 2,
			"versionNonce": 421582974,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1777105885443,
			"link": null,
			"locked": false,
			"text": "这样画的好处：\n• 不再误解成“框架层在系统组件层之下”\n• 不再把对象当成底层已有物\n• 更符合语义服务的真实依赖关系",
			"fontSize": 15,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"baseline": 13,
			"containerId": null,
			"originalText": "这样画的好处：\n• 不再误解成“框架层在系统组件层之下”\n• 不再把对象当成底层已有物\n• 更符合语义服务的真实依赖关系",
			"lineHeight": 1.22,
			"autoResize": true,
			"index": "av",
			"hasTextLink": false,
			"rawText": ""
		},
