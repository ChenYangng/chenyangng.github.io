			"seed": 1439712671,
			"version": 2,
			"versionNonce": 1828819006,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1777105885443,
			"link": null,
			"locked": false,
			"text": "读图方式：\n• 左下：UI运行时/框架域\n  回答“界面从哪里来”\n• 右下：系统能力接口域\n  回答“系统能拿到什么”\n• 中间：语义服务层\n  在两者之上做高阶加工",
			"fontSize": 15,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"baseline": 13,
			"containerId": null,
			"originalText": "读图方式：\n• 左下：UI运行时/框架域\n  回答“界面从哪里来”\n• 右下：系统能力接口域\n  回答“系统能拿到什么”\n• 中间：语义服务层\n  在两者之上做高阶加工",
			"lineHeight": 1.22,
			"autoResize": true,
			"index": "at",
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"id": "e60890608",
