		{
			"id": "nprnom64",
			"type": "text",
			"x": 205,
			"y": 872,
			"width": 1446.5,
			"height": 19.52,
			"angle": 0,
			"strokeColor": "#111827",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"roundness": null,
			"seed": 575108025,
			"version": 2,
			"versionNonce": 1252858046,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1777105885443,
			"link": null,
			"locked": false,
			"text": "一句话：Semantic UI Service 的下方不是单一“底层”，而是两个并列支撑域——左侧 UI运行时/框架域提供界面来源，右侧系统能力接口域提供观测与执行接口；语义对象与状态理解都在中间层产出。",
			"fontSize": 16,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"baseline": 14,
			"containerId": null,
			"originalText": "一句话：Semantic UI Service 的下方不是单一“底层”，而是两个并列支撑域——左侧 UI运行时/框架域提供界面来源，右侧系统能力接口域提供观测与执行接口；语义对象与状态理解都在中间层产出。",
			"lineHeight": 1.22,
			"autoResize": true,
			"index": "ax",
			"hasTextLink": false,
			"rawText": ""
		}
